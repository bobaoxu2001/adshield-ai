# Optional: official Meta Ad Library enrichment.
# Paste your token ONLY into a local .env file (never commit it; .env is gitignored).
META_ACCESS_TOKEN=
# Comma-separated ISO country codes to query (UK/EU give the broadest commercial coverage).
META_AD_COUNTRIES=GB,IE,FR,DE,NL,ES,IT
# Comma-separated Ad Library ad types. ALL is the safe fallback; the special categories
# (financial/employment/housing) are only available in some countries.
META_AD_TYPES=FINANCIAL_PRODUCTS_AND_SERVICES_ADS,EMPLOYMENT_ADS,HOUSING_ADS,ALL
# How many pages of results to follow per (country, ad_type, keyword) query.
META_MAX_PAGES_PER_QUERY=3
META_GRAPH_API_VERSION=v23.0

# Optional: LLM comparison. Deterministic scoring is always available.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Ingestion controls.
CFPB_MAX_RECORDS=1000
ADSHIELD_DB_PATH=data/processed/adshield.duckdb
